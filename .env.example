API_PORT=4317
WEB_PORT=5179
PMW_API_URL=http://localhost:4317
VITE_API_URL=http://localhost:4317

# --- Supabase (Playback project) ---
SUPABASE_URL=https://YOUR_PROJECT.supabase.co
# Grab from https://supabase.com/dashboard/project/YOUR_PROJECT/settings/api
# Use the SERVICE_ROLE key (bypasses RLS). Never expose to the browser.
SUPABASE_SERVICE_ROLE_KEY=
# Production should require Bearer JWTs on owner/library mutations and account
# reads. Local/offline dev can leave this unset to keep x-user-id fallback.
REQUIRE_JWT_AUTH=true

# --- Ask assistant (Claude-backed workspace Q&A) ---
# When set, POST /assistant/ask answers with claude-opus-4-8 over a read-only
# snapshot of the workspace (context-aware, cited). When UNSET, the endpoint
# falls back to the deterministic keyword matcher — so it's safe to leave blank.
# Get a key at https://console.anthropic.com/settings/keys
# PRE-FLIGHT before setting this in prod: add rate-limiting + auth to
# /assistant/ask (currently open) so anonymous callers can't drive Opus spend.
ANTHROPIC_API_KEY=

# --- File storage (future: real audio uploads) ---
CLOUDFLARE_R2_ENDPOINT=
CLOUDFLARE_R2_ACCESS_KEY_ID=
CLOUDFLARE_R2_SECRET_ACCESS_KEY=
CLOUDFLARE_R2_BUCKET=

# --- Background jobs (future) ---
REDIS_URL=redis://localhost:6379

# --- Email / invite delivery ---
# When unset, recipient invites are saved and the UI asks you to copy/send the
# link manually. When set, the API can queue provider-backed invite delivery.
EMAIL_PROVIDER_API_KEY=
